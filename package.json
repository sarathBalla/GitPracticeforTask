  "main": "index.js",
  "scripts": {
    "test-dev-chrome": "cross-env ENV_NAME=demo npx playwright test --project=chromium --headed",
    "test-pipeline-chrome": "cross-env ENV_NAME=demo npx playwright test --project=chromium",
    "test-api-local": "cross-env ENV_NAME=demo npx playwright test --project=apiTest --grep \"@API\"",
    "test-api": "cross-env ENV_NAME=demo npx playwright test --project=chromium --project=apiTest --grep \"@UAT|@API\"",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "allure:clean": "if exist allure-results rmdir /s /q allure-results && if exist allure-report rmdir /s /q allure-report"
  },
